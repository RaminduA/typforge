# Docker images
TYPFORGE_API_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/typforge-api:latest
TYPFORGE_TYPST_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/typforge-typst-runner:latest

# Runtime
PORT=8080
STORAGE_ROOT=/opt/typforge/storage
TYPST_ALLOW_NETWORK=true
TYPST_PACKAGE_CACHE_DIR=/opt/typforge/storage/typst-package-cache
TYPST_FONT_DIR=/opt/typforge/storage/typst-fonts

# Public API domain
# Example generated domain:
# 123-45-67-89.sslip.io
API_DOMAIN=YOUR_API_DOMAIN

# CORS origin.
# For MVP, * is acceptable if you are not using cookies/auth.
CORS_ORIGIN=*

# Optional
ACME_EMAIL=