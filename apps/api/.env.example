# API server
PORT=0000

# Storage
# Replace with the actual storage directory used by your local/backend setup.
STORAGE_ROOT=./path/to/storage

# Typst compiler
# Replace with the exact Typst Docker image you want to use.
TYPST_DOCKER_IMAGE=example-registry/example-typst-image:example-tag

# Compile timeout
# Replace with a real timeout value in seconds.
COMPILE_TIMEOUT_SECONDS=00

# Remote Typst Universe packages/templates
# Set to true only when you want the compiler to download remote packages.
TYPST_ALLOW_NETWORK=false

# Typst package cache
# Replace with the actual directory where downloaded Typst packages should be cached.
TYPST_PACKAGE_CACHE_DIR=./path/to/typst-package-cache

# Typst fonts
# Replace with the actual directory where downloaded Typst fonts should be stored.
TYPST_FONT_DIR=.path/to/typst-fonts